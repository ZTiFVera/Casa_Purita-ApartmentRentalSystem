<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Casa_Purita_ApartmentRentalSystem.MVVM.Views.MainView"
             Title="Casa Purita Apartment"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F0F13">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- HERO HEADER -->
        <Grid Grid.Row="0" BackgroundColor="#0F0F13">
            <BoxView HeightRequest="2"
                     VerticalOptions="Start"
                     Color="#C9A96E"/>

            <StackLayout Padding="24,28,24,20" Spacing="4">

                <Grid ColumnDefinitions="*, Auto" Margin="0,6,0,0">
                    <StackLayout Grid.Column="0" Spacing="2">
                        <Label Text="CASA PURITA"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#C9A96E"
                               CharacterSpacing="4"/>
                        <Label Text="Residence Management"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#F0EDE8"/>
                    </StackLayout>

                    <Frame Grid.Column="1"
                           BackgroundColor="#1A1A22"
                           BorderColor="#2A2A35"
                           CornerRadius="20"
                           Padding="12,6"
                           VerticalOptions="Center">
                        <StackLayout Orientation="Horizontal" Spacing="6" VerticalOptions="Center">
                            <BoxView WidthRequest="7" HeightRequest="7"
                                     CornerRadius="4"
                                     Color="#4CAF50"
                                     VerticalOptions="Center"/>
                            <Label Text="LIVE"
                                   FontSize="10"
                                   FontAttributes="Bold"
                                   TextColor="#4CAF50"
                                   CharacterSpacing="2"
                                   VerticalOptions="Center"/>
                        </StackLayout>
                    </Frame>
                </Grid>

                <BoxView HeightRequest="1"
                         Color="#1E1E28"
                         Margin="0,12,0,0"/>

                <StackLayout Orientation="Horizontal" Spacing="8" Margin="0,8,0,0">
                    <Label Text="⌂"
                           FontSize="15"
                           TextColor="#C9A96E"
                           VerticalOptions="Center"/>
                    <Label Text="All Residents"
                           FontSize="13"
                           TextColor="#7A7A8A"
                           VerticalOptions="Center"/>
                </StackLayout>
            </StackLayout>
        </Grid>

        <!-- BUTTONS ROW -->
        <Grid Grid.Row="1"
              Padding="24,0,24,16"
              BackgroundColor="#0F0F13"
              RowDefinitions="Auto,Auto"
              RowSpacing="10">

            <Frame Grid.Row="0"
                   BackgroundColor="#C9A96E"
                   CornerRadius="14"
                   Padding="0"
                   BorderColor="Transparent"
                   HasShadow="False">
                <Button Text="＋  ADD NEW RESIDENT"
                        Clicked="OnAddTenantClicked"
                        BackgroundColor="Transparent"
                        TextColor="#0F0F13"
                        FontAttributes="Bold"
                        FontSize="13"
                        CharacterSpacing="2"
                        HeightRequest="52"/>
            </Frame>

            <Frame Grid.Row="1"
                   BackgroundColor="#16161F"
                   CornerRadius="14"
                   Padding="0"
                   BorderColor="#2A1A1A"
                   HasShadow="False">
                <Button Text="⊘  VIEW HIDDEN RESIDENTS"
                        Clicked="OnViewDeletedClicked"
                        BackgroundColor="Transparent"
                        TextColor="#C96E6E"
                        FontAttributes="Bold"
                        FontSize="12"
                        CharacterSpacing="2"
                        HeightRequest="44"/>
            </Frame>
        </Grid>

        <!-- TENANT LIST -->
        <RefreshView Grid.Row="2"
                     x:Name="refreshView"
                     Refreshing="OnRefreshing"
                     RefreshColor="#C9A96E"
                     BackgroundColor="#0F0F13">
            <CollectionView x:Name="TenantsCollectionView"
                            Margin="0"
                            BackgroundColor="#0F0F13">

                <CollectionView.EmptyView>
                    <StackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Padding="40"
                                 Spacing="12">
                        <Label Text="⌂"
                               FontSize="52"
                               TextColor="#C9A96E"
                               HorizontalOptions="Center"/>
                        <Label Text="No Residents Yet"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#F0EDE8"
                               HorizontalOptions="Center"/>
                        <Label Text="Tap 'Add New Resident' to begin."
                               FontSize="13"
                               TextColor="#5A5A6A"
                               HorizontalOptions="Center"/>
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="20,6,20,6">
                            <Frame Padding="0"
                                   CornerRadius="18"
                                   BorderColor="#1E1E2C"
                                   BackgroundColor="#16161F"
                                   HasShadow="False">
                                <Grid RowDefinitions="Auto,Auto,Auto">

                                    <BoxView Grid.Row="0"
                                             HeightRequest="2"
                                             Color="#C9A96E"
                                             HorizontalOptions="Fill"/>

                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="Auto,*"
                                          Padding="18,16,18,14"
                                          ColumnSpacing="14">

                                        <Frame Grid.Column="0"
                                               WidthRequest="48"
                                               HeightRequest="48"
                                               CornerRadius="24"
                                               BackgroundColor="#1F1F2C"
                                               BorderColor="#2A2A3C"
                                               Padding="0"
                                               VerticalOptions="Start">
                                            <Label Text="⌂"
                                                   FontSize="22"
                                                   TextColor="#C9A96E"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Frame>

                                        <StackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding FullName}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#F0EDE8"/>
                                            <Label Text="{Binding Email}"
                                                   FontSize="12"
                                                   TextColor="#6A6A7A"/>
                                            <Label Text="{Binding PhoneNumber}"
                                                   FontSize="12"
                                                   TextColor="#6A6A7A"/>

                                            <StackLayout Orientation="Horizontal"
                                                         Spacing="8"
                                                         Margin="0,6,0,0">
                                                <Frame BackgroundColor="#1A2A1A"
                                                       BorderColor="#2A3D2A"
                                                       CornerRadius="8"
                                                       Padding="10,4">
                                                    <Label Text="{Binding UnitNumber, StringFormat='Unit {0}'}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="#5DB85D"/>
                                                </Frame>
                                                <Frame BackgroundColor="#2A1A1A"
                                                       BorderColor="#3D2A2A"
                                                       CornerRadius="8"
                                                       Padding="10,4">
                                                    <Label Text="{Binding MonthlyRent, StringFormat='₱{0:N0}/mo'}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="#C97A6E"/>
                                                </Frame>
                                            </StackLayout>
                                        </StackLayout>
                                    </Grid>

                                    <Grid Grid.Row="2"
                                          ColumnDefinitions="*,*,*"
                                          BackgroundColor="#12121A"
                                          ColumnSpacing="0">

                                        <Button Grid.Column="0"
                                                Text="Edit"
                                                BackgroundColor="Transparent"
                                                TextColor="#C9A96E"
                                                FontSize="12"
                                                FontAttributes="Bold"
                                                HeightRequest="44"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnEditClicked"/>

                                        <BoxView Grid.Column="0"
                                                 WidthRequest="1"
                                                 HeightRequest="20"
                                                 Color="#2A2A3A"
                                                 HorizontalOptions="End"
                                                 VerticalOptions="Center"/>

                                        <Button Grid.Column="1"
                                                Text="Hide"
                                                BackgroundColor="Transparent"
                                                TextColor="#8A8A9A"
                                                FontSize="12"
                                                HeightRequest="44"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnSoftDeleteClicked"
                                                FontAttributes="Bold"/>
                                                

                                        <BoxView Grid.Column="1"
                                                 WidthRequest="1"
                                                 HeightRequest="20"
                                                 Color="#2A2A3A"
                                                 HorizontalOptions="End"
                                                 VerticalOptions="Center"/>

                                        <Button Grid.Column="2"
                                                Text="Delete"
                                                BackgroundColor="Transparent"
                                                TextColor="#C96E6E"
                                                FontSize="12"
                                                HeightRequest="44"
                                                FontAttributes="Bold"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnHardDeleteClicked"/>
                                    </Grid>

                                </Grid>
                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>