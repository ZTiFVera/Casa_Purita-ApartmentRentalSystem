<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Casa_Purita_ApartmentRentalSystem.MVVM.Views.UpdateView"
             Title="Update Tenant"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F0F13">

    <Grid RowDefinitions="Auto, *">

        <!-- HEADER -->
        <Grid Grid.Row="0" BackgroundColor="#0F0F13">
            <BoxView HeightRequest="2"
                     VerticalOptions="Start"
                     Color="#C9A96E"/>
            <StackLayout Padding="24,28,24,20" Spacing="4">
                <Label Text="CASA PURITA"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#C9A96E"
                       CharacterSpacing="4"
                       Margin="0,6,0,0"/>
                <Label Text="Edit Resident"
                       FontSize="22"
                       FontAttributes="Bold"
                       TextColor="#F0EDE8"/>
                <BoxView HeightRequest="1" Color="#1E1E28" Margin="0,10,0,0"/>
                <StackLayout Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                    <Label Text="✎"
                           FontSize="15"
                           TextColor="#C9A96E"
                           VerticalOptions="Center"/>
                    <Label Text="Update resident information"
                           FontSize="13"
                           TextColor="#7A7A8A"
                           VerticalOptions="Center"/>
                </StackLayout>
            </StackLayout>
        </Grid>

        <!-- FORM -->
        <ScrollView Grid.Row="1" BackgroundColor="#0F0F13">
            <StackLayout Padding="20,8,20,40" Spacing="0">

                <Label Text="PERSONAL INFO"
                       FontSize="10"
                       FontAttributes="Bold"
                       TextColor="#C9A96E"
                       CharacterSpacing="3"
                       Margin="4,16,0,12"/>

                <Frame BackgroundColor="#16161F"
                       BorderColor="#1E1E2C"
                       CornerRadius="18"
                       Padding="0"
                       HasShadow="False"
                       Margin="0,0,0,16">
                    <StackLayout Spacing="0">
                        <StackLayout Padding="18,16,18,12">
                            <Label Text="First Name"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#6A6A7A"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="FirstNameEntry"
                                   PlaceholderColor="#3A3A4A"
                                   TextColor="#F0EDE8"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                        <BoxView HeightRequest="1" Color="#1E1E2C" Margin="18,0"/>
                        <StackLayout Padding="18,14,18,12">
                            <Label Text="Last Name"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#6A6A7A"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="LastNameEntry"
                                   PlaceholderColor="#3A3A4A"
                                   TextColor="#F0EDE8"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                    </StackLayout>
                </Frame>

                <Label Text="CONTACT"
                       FontSize="10"
                       FontAttributes="Bold"
                       TextColor="#C9A96E"
                       CharacterSpacing="3"
                       Margin="4,0,0,12"/>

                <Frame BackgroundColor="#16161F"
                       BorderColor="#1E1E2C"
                       CornerRadius="18"
                       Padding="0"
                       HasShadow="False"
                       Margin="0,0,0,16">
                    <StackLayout Spacing="0">
                        <StackLayout Padding="18,16,18,12">
                            <Label Text="Email Address"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#6A6A7A"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="EmailEntry"
                                   PlaceholderColor="#3A3A4A"
                                   TextColor="#F0EDE8"
                                   BackgroundColor="Transparent"
                                   Keyboard="Email"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                        <BoxView HeightRequest="1" Color="#1E1E2C" Margin="18,0"/>
                        <StackLayout Padding="18,14,18,12">
                            <Label Text="Phone Number"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#6A6A7A"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="PhoneEntry"
                                   PlaceholderColor="#3A3A4A"
                                   TextColor="#F0EDE8"
                                   BackgroundColor="Transparent"
                                   Keyboard="Telephone"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                    </StackLayout>
                </Frame>

                <Label Text="UNIT DETAILS"
                       FontSize="10"
                       FontAttributes="Bold"
                       TextColor="#C9A96E"
                       CharacterSpacing="3"
                       Margin="4,0,0,12"/>

                <Frame BackgroundColor="#16161F"
                       BorderColor="#1E1E2C"
                       CornerRadius="18"
                       Padding="0"
                       HasShadow="False"
                       Margin="0,0,0,16">
                    <StackLayout Spacing="0">
                        <StackLayout Padding="18,16,18,12">
                            <Label Text="Unit Number"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#6A6A7A"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="UnitNumberEntry"
                                   PlaceholderColor="#3A3A4A"
                                   TextColor="#F0EDE8"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                        <BoxView HeightRequest="1" Color="#1E1E2C" Margin="18,0"/>
                        <StackLayout Padding="18,14,18,12">
                            <Label Text="Move-In Date"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#6A6A7A"
                                   CharacterSpacing="1"/>
                            <DatePicker x:Name="MoveInDatePicker"
                                        TextColor="#F0EDE8"
                                        BackgroundColor="Transparent"
                                        FontSize="16"
                                        Margin="0,4,0,0"/>
                        </StackLayout>
                        <BoxView HeightRequest="1" Color="#1E1E2C" Margin="18,0"/>
                        <StackLayout Padding="18,14,18,16">
                            <Label Text="Monthly Rent (₱)"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#6A6A7A"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="MonthlyRentEntry"
                                   PlaceholderColor="#3A3A4A"
                                   TextColor="#C9A96E"
                                   BackgroundColor="Transparent"
                                   Keyboard="Numeric"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                    </StackLayout>
                </Frame>

                <Frame BackgroundColor="#C9A96E"
                       CornerRadius="16"
                       Padding="0"
                       BorderColor="Transparent"
                       HasShadow="False"
                       Margin="0,8,0,0">
                    <Button Text="⊕  SAVE CHANGES"
                            Clicked="OnUpdateClicked"
                            BackgroundColor="Transparent"
                            TextColor="#0F0F13"
                            FontAttributes="Bold"
                            FontSize="14"
                            CharacterSpacing="2"
                            HeightRequest="56"/>
                </Frame>

                <Frame BackgroundColor="#16161F"
                       CornerRadius="16"
                       Padding="0"
                       BorderColor="#1E1E2C"
                       HasShadow="False"
                       Margin="0,12,0,0">
                    <Button Text="✕  CANCEL"
                            Clicked="OnCancelClicked"
                            BackgroundColor="Transparent"
                            TextColor="#5A5A6A"
                            FontAttributes="Bold"
                            FontSize="13"
                            CharacterSpacing="2"
                            HeightRequest="48"/>
                </Frame>

            </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>