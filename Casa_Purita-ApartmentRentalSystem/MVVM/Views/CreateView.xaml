<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Casa_Purita_ApartmentRentalSystem.MVVM.Views.CreateView"
             Title="Add New Tenant"
             BackgroundColor="#F5F5F5">

    <ScrollView>
        <StackLayout Padding="20" Spacing="15">

            <!-- HEADER -->
            <StackLayout BackgroundColor="#1A3C5E" Padding="20,15" Margin="-20,-20,-20,10">
                <Label Text="➕ Add New Tenant"
                       FontSize="20"
                       FontAttributes="Bold"
                       TextColor="White"
                       HorizontalOptions="Center"/>
            </StackLayout>

            <!-- FIRST NAME -->
            <Label Text="First Name" FontAttributes="Bold" TextColor="#1A3C5E"/>
            <Entry x:Name="FirstNameEntry"
                   Placeholder="Enter first name"
                   BackgroundColor="White"/>

            <!-- LAST NAME -->
            <Label Text="Last Name" FontAttributes="Bold" TextColor="#1A3C5E"/>
            <Entry x:Name="LastNameEntry"
                   Placeholder="Enter last name"
                   BackgroundColor="White"/>

            <!-- EMAIL -->
            <Label Text="Email" FontAttributes="Bold" TextColor="#1A3C5E"/>
            <Entry x:Name="EmailEntry"
                   Placeholder="Enter email address"
                   Keyboard="Email"
                   BackgroundColor="White"/>

            <!-- PHONE -->
            <Label Text="Phone Number" FontAttributes="Bold" TextColor="#1A3C5E"/>
            <Entry x:Name="PhoneEntry"
                   Placeholder="Enter phone number"
                   Keyboard="Telephone"
                   BackgroundColor="White"/>

            <!-- UNIT NUMBER -->
            <Label Text="Unit Number" FontAttributes="Bold" TextColor="#1A3C5E"/>
            <Entry x:Name="UnitNumberEntry"
                   Placeholder="e.g. Unit 101"
                   BackgroundColor="White"/>

            <!-- MOVE IN DATE -->
            <Label Text="Move-In Date" FontAttributes="Bold" TextColor="#1A3C5E"/>
            <DatePicker x:Name="MoveInDatePicker"
                        BackgroundColor="White"/>

            <!-- MONTHLY RENT -->
            <Label Text="Monthly Rent (₱)" FontAttributes="Bold" TextColor="#1A3C5E"/>
            <Entry x:Name="MonthlyRentEntry"
                   Placeholder="Enter monthly rent amount"
                   Keyboard="Numeric"
                   BackgroundColor="White"/>

            <!-- SAVE BUTTON -->
            <Button Text="💾 Save Tenant"
                    Clicked="OnSaveClicked"
                    BackgroundColor="#2ECC71"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="50"
                    Margin="0,10,0,0"/>

            <!-- CANCEL BUTTON -->
            <Button Text="✖ Cancel"
                    Clicked="OnCancelClicked"
                    BackgroundColor="#E74C3C"
                    TextColor="White"
                    FontAttributes="Bold"
                    CornerRadius="8"
                    HeightRequest="50"/>

        </StackLayout>
    </ScrollView>

</ContentPage>