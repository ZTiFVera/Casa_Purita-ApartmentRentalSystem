<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Casa_Purita_ApartmentRentalSystem.MVVM.Views.CreateView"
             Title="Add New Tenant"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0B0B0F">
    <Grid RowDefinitions="Auto, *">

        <Grid Grid.Row="0" BackgroundColor="#0B0B0F">
            <BoxView HeightRequest="3"
                     VerticalOptions="Start"
                     Color="#D4AF37"/>
            <StackLayout Padding="24,28,24,20" Spacing="4">
                <Label Text="HOME VILLE"
                       FontSize="11"
                       FontAttributes="Bold"
                       TextColor="#D4AF37"
                       CharacterSpacing="4"
                       Margin="0,6,0,0"/>
                <Label Text="New Resident"
                       FontSize="24"
                       FontAttributes="Bold"
                       TextColor="#F8F8F8"/>
                <BoxView HeightRequest="1" Color="#252533" Margin="0,10,0,0"/>

                <StackLayout Orientation="Horizontal" Spacing="8" Margin="0,6,0,0">
                    <Label Text="◈"
                           FontSize="15"
                           TextColor="#D4AF37"
                           VerticalOptions="Center"/>
                    <Label Text="Fill in the details below"
                           FontSize="13"
                           TextColor="#A0A0B0" 
                           VerticalOptions="Center"/>
                </StackLayout>
            </StackLayout>
        </Grid>

        <ScrollView Grid.Row="1">
            <StackLayout Padding="20,8,20,40" Spacing="0">

                <Label Text="PERSONAL INFO"
                       FontSize="10"
                       FontAttributes="Bold"
                       TextColor="#D4AF37"
                       CharacterSpacing="3"
                       Margin="4,16,0,12"/>

                <Frame BackgroundColor="#1C1C26" 
                       BorderColor="#2D2D3D"
                       CornerRadius="18"
                       Padding="0"
                       HasShadow="False"
                       Margin="0,0,0,16">
                    <StackLayout Spacing="0">
                        <StackLayout Padding="18,16,18,12">
                            <Label Text="First Name"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#7E7E8F"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="FirstNameEntry"
                                   Placeholder="e.g. Maria"
                                   PlaceholderColor="#4A4A5A"
                                   TextColor="#E8E8E8" 
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                        <BoxView HeightRequest="1" Color="#2D2D3D" Margin="18,0"/>
                        <StackLayout Padding="18,14,18,12">
                            <Label Text="Last Name"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#7E7E8F"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="LastNameEntry"
                                   Placeholder="e.g. Santos"
                                   PlaceholderColor="#4A4A5A"
                                   TextColor="#E8E8E8"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                    </StackLayout>
                </Frame>

                <Label Text="CONTACT"
                       FontSize="10"
                       FontAttributes="Bold"
                       TextColor="#D4AF37"
                       CharacterSpacing="3"
                       Margin="4,0,0,12"/>

                <Frame BackgroundColor="#1C1C26"
                       BorderColor="#2D2D3D"
                       CornerRadius="18"
                       Padding="0"
                       HasShadow="False"
                       Margin="0,0,0,16">
                    <StackLayout Spacing="0">
                        <StackLayout Padding="18,16,18,12">
                            <Label Text="Email Address"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#7E7E8F"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="EmailEntry"
                                   Placeholder="email@example.com"
                                   PlaceholderColor="#4A4A5A"
                                   TextColor="#E8E8E8"
                                   BackgroundColor="Transparent"
                                   Keyboard="Email"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                        <BoxView HeightRequest="1" Color="#2D2D3D" Margin="18,0"/>
                        <StackLayout Padding="18,14,18,12">
                            <Label Text="Phone Number"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#7E7E8F"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="PhoneEntry"
                                   Placeholder="09XXXXXXXXX"
                                   PlaceholderColor="#4A4A5A"
                                   TextColor="#E8E8E8"
                                   BackgroundColor="Transparent"
                                   Keyboard="Telephone"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                    </StackLayout>
                </Frame>

                <Label Text="UNIT DETAILS"
                       FontSize="10"
                       FontAttributes="Bold"
                       TextColor="#D4AF37"
                       CharacterSpacing="3"
                       Margin="4,0,0,12"/>

                <Frame BackgroundColor="#1C1C26"
                       BorderColor="#2D2D3D"
                       CornerRadius="18"
                       Padding="0"
                       HasShadow="False"
                       Margin="0,0,0,16">
                    <StackLayout Spacing="0">
                        <StackLayout Padding="18,16,18,12">
                            <Label Text="Unit Number"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#7E7E8F"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="UnitNumberEntry"
                                   Placeholder="e.g. 101, 2B"
                                   PlaceholderColor="#4A4A5A"
                                   TextColor="#E8E8E8"
                                   BackgroundColor="Transparent"
                                   FontSize="16"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                        <BoxView HeightRequest="1" Color="#2D2D3D" Margin="18,0"/>
                        <StackLayout Padding="18,14,18,12">
                            <Label Text="Move-In Date"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#7E7E8F"
                                   CharacterSpacing="1"/>
                            <DatePicker x:Name="MoveInDatePicker"
                                        TextColor="#E8E8E8"
                                        BackgroundColor="Transparent"
                                        FontSize="16"
                                        Margin="0,4,0,0"/>
                        </StackLayout>
                        <BoxView HeightRequest="1" Color="#2D2D3D" Margin="18,0"/>
                        <StackLayout Padding="18,14,18,16">
                            <Label Text="Monthly Rent (₱)"
                                   FontSize="11"
                                   FontAttributes="Bold"
                                   TextColor="#7E7E8F"
                                   CharacterSpacing="1"/>
                            <Entry x:Name="MonthlyRentEntry"
                                   Placeholder="0.00"
                                   PlaceholderColor="#4A4A5A"
                                   TextColor="#D4AF37"
                                   BackgroundColor="Transparent"
                                   Keyboard="Numeric"
                                   FontSize="20"
                                   FontAttributes="Bold"
                                   Margin="0,4,0,0"/>
                        </StackLayout>
                    </StackLayout>
                </Frame>

                <Frame BackgroundColor="#D4AF37"
                       CornerRadius="16"
                       Padding="0"
                       BorderColor="Transparent"
                       HasShadow="True"
                       Margin="0,8,0,0">
                    <Button Text="SAVE RESIDENT"
                            Clicked="OnSaveClicked"
                            BackgroundColor="Transparent"
                            TextColor="#0B0B0F"
                            FontAttributes="Bold"
                            FontSize="14"
                            CharacterSpacing="2"
                            HeightRequest="56"/>
                </Frame>

                <Frame BackgroundColor="Transparent"
                       CornerRadius="16"
                       Padding="0"
                       BorderColor="#2D2D3D"
                       HasShadow="False"
                       Margin="0,12,0,0">
                    <Button Text="CANCEL"
                            Clicked="OnCancelClicked"
                            BackgroundColor="Transparent"
                            TextColor="#7E7E8F"
                            FontAttributes="Bold"
                            FontSize="13"
                            CharacterSpacing="2"
                            HeightRequest="48"/>
                </Frame>

            </StackLayout>
        </ScrollView>
    </Grid>
</ContentPage>