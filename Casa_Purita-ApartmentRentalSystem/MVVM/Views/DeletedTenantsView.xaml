<?xml version="1.0" encoding="utf-8" ?>
<ContentPage xmlns="http://schemas.microsoft.com/dotnet/2021/maui"
             xmlns:x="http://schemas.microsoft.com/winfx/2009/xaml"
             x:Class="Casa_Purita_ApartmentRentalSystem.MVVM.Views.DeletedTenantsView"
             Title="Deleted Profile"
             Shell.NavBarIsVisible="False"
             BackgroundColor="#0F0F13">

    <Grid RowDefinitions="Auto, Auto, *">

        <!-- HEADER -->
        <Grid Grid.Row="0" BackgroundColor="#0F0F13">
            <BoxView HeightRequest="2"
                     VerticalOptions="Start"
                     Color="#C96E6E"/>
            <StackLayout Padding="24,28,24,20" Spacing="4">
                <Grid ColumnDefinitions="Auto, *" Margin="0,6,0,0" ColumnSpacing="12">

                    <!-- Back Button -->
                    <Frame Grid.Column="0"
                           BackgroundColor="#16161F"
                           BorderColor="#1E1E2C"
                           CornerRadius="12"
                           Padding="10,8"
                           VerticalOptions="Center">
                        <Label Text="← Back"
                               FontSize="12"
                               FontAttributes="Bold"
                               TextColor="#7A7A8A">
                            <Label.GestureRecognizers>
                                <TapGestureRecognizer Tapped="OnBackClicked"/>
                            </Label.GestureRecognizers>
                        </Label>
                    </Frame>

                    <StackLayout Grid.Column="1" Spacing="2">
                        <Label Text="CASA PURITA"
                               FontSize="11"
                               FontAttributes="Bold"
                               TextColor="#C96E6E"
                               CharacterSpacing="4"/>
                        <Label Text="Hidden Residents"
                               FontSize="22"
                               FontAttributes="Bold"
                               TextColor="#F0EDE8"/>
                    </StackLayout>
                </Grid>

                <BoxView HeightRequest="1" Color="#1E1E28" Margin="0,12,0,0"/>
                <Label Text="🚫  Soft-deleted residents"
                       FontSize="13"
                       TextColor="#7A7A8A"
                       Margin="0,6,0,0"/>
            </StackLayout>
        </Grid>

        <!-- COUNT BADGE -->
        <StackLayout Grid.Row="1"
                     Padding="24,0,24,16"
                     BackgroundColor="#0F0F13">
            <Frame BackgroundColor="#2A1A1A"
                   BorderColor="#3D2A2A"
                   CornerRadius="12"
                   Padding="16,10"
                   HasShadow="False">
                <Label x:Name="CountLabel"
                       Text="Loading..."
                       FontSize="13"
                       FontAttributes="Bold"
                       TextColor="#C96E6E"
                       HorizontalOptions="Center"/>
            </Frame>
        </StackLayout>

        <!-- DELETED TENANT LIST -->
        <RefreshView Grid.Row="2"
                     x:Name="refreshView"
                     Refreshing="OnRefreshing"
                     RefreshColor="#C96E6E"
                     BackgroundColor="#0F0F13">
            <CollectionView x:Name="DeletedTenantsCollectionView"
                            BackgroundColor="#0F0F13">

                <CollectionView.EmptyView>
                    <StackLayout HorizontalOptions="Center"
                                 VerticalOptions="Center"
                                 Padding="40"
                                 Spacing="12">
                        <Label Text="✅"
                               FontSize="52"
                               HorizontalOptions="Center"/>
                        <Label Text="No Hidden Residents"
                               FontSize="18"
                               FontAttributes="Bold"
                               TextColor="#F0EDE8"
                               HorizontalOptions="Center"/>
                        <Label Text="All residents are currently visible."
                               FontSize="13"
                               TextColor="#5A5A6A"
                               HorizontalOptions="Center"/>
                    </StackLayout>
                </CollectionView.EmptyView>

                <CollectionView.ItemTemplate>
                    <DataTemplate>
                        <Grid Padding="20,6,20,6">
                            <Frame Padding="0"
                                   CornerRadius="18"
                                   BorderColor="#2A1A1A"
                                   BackgroundColor="#16161F"
                                   HasShadow="False">
                                <Grid RowDefinitions="Auto,Auto,Auto">

                                    <!-- Red top accent for deleted -->
                                    <BoxView Grid.Row="0"
                                             HeightRequest="2"
                                             Color="#C96E6E"
                                             HorizontalOptions="Fill"/>

                                    <!-- Tenant info -->
                                    <Grid Grid.Row="1"
                                          ColumnDefinitions="Auto,*"
                                          Padding="18,16,18,14"
                                          ColumnSpacing="14">

                                        <!-- Avatar -->
                                        <Frame Grid.Column="0"
                                               WidthRequest="48"
                                               HeightRequest="48"
                                               CornerRadius="24"
                                               BackgroundColor="#2A1A1A"
                                               BorderColor="#3D2A2A"
                                               Padding="0"
                                               VerticalOptions="Start">
                                            <Label Text="🚫"
                                                   FontSize="22"
                                                   HorizontalOptions="Center"
                                                   VerticalOptions="Center"/>
                                        </Frame>

                                        <StackLayout Grid.Column="1" Spacing="3">
                                            <Label Text="{Binding FullName}"
                                                   FontSize="16"
                                                   FontAttributes="Bold"
                                                   TextColor="#F0EDE8"/>
                                            <Label Text="{Binding Email}"
                                                   FontSize="12"
                                                   TextColor="#6A6A7A"/>
                                            <Label Text="{Binding PhoneNumber}"
                                                   FontSize="12"
                                                   TextColor="#6A6A7A"/>

                                            <StackLayout Orientation="Horizontal"
                                                         Spacing="8"
                                                         Margin="0,6,0,0">
                                                <Frame BackgroundColor="#1A2A1A"
                                                       BorderColor="#2A3D2A"
                                                       CornerRadius="8"
                                                       Padding="10,4">
                                                    <Label Text="{Binding UnitNumber, StringFormat='Unit {0}'}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="#5DB85D"/>
                                                </Frame>
                                                <Frame BackgroundColor="#2A1A1A"
                                                       BorderColor="#3D2A2A"
                                                       CornerRadius="8"
                                                       Padding="10,4">
                                                    <Label Text="{Binding MonthlyRent, StringFormat='₱{0:N0}/mo'}"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="#C97A6E"/>
                                                </Frame>
                                                <!-- Hidden badge -->
                                                <Frame BackgroundColor="#2A1A1A"
                                                       BorderColor="#3D2A2A"
                                                       CornerRadius="8"
                                                       Padding="10,4">
                                                    <Label Text="HIDDEN"
                                                           FontSize="11"
                                                           FontAttributes="Bold"
                                                           TextColor="#C96E6E"/>
                                                </Frame>
                                            </StackLayout>
                                        </StackLayout>
                                    </Grid>

                                    <!-- Action buttons -->
                                    <Grid Grid.Row="2"
                                          ColumnDefinitions="*,*"
                                          BackgroundColor="#12121A"
                                          ColumnSpacing="0">

                                        <Button Grid.Column="0"
                                                Text="♻  Restore"
                                                BackgroundColor="Transparent"
                                                TextColor="#5DB85D"
                                                FontSize="12"
                                                FontAttributes="Bold"
                                                HeightRequest="44"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnRestoreClicked"/>

                                        <BoxView Grid.Column="0"
                                                 WidthRequest="1"
                                                 HeightRequest="20"
                                                 Color="#2A2A3A"
                                                 HorizontalOptions="End"
                                                 VerticalOptions="Center"/>

                                        <Button Grid.Column="1"
                                                Text="🗑  Delete Forever"
                                                BackgroundColor="Transparent"
                                                TextColor="#C96E6E"
                                                FontSize="12"
                                                HeightRequest="44"
                                                CommandParameter="{Binding .}"
                                                Clicked="OnHardDeleteClicked"/>
                                    </Grid>

                                </Grid>
                            </Frame>
                        </Grid>
                    </DataTemplate>
                </CollectionView.ItemTemplate>

            </CollectionView>
        </RefreshView>

    </Grid>
</ContentPage>
```

